# Backend API (Express `/api/v1`). When set, admin + public forms use the live API; otherwise CRM uses localStorage.
# Match CORS: set backend `CLIENT_URL` to this app's origin (e.g. http://localhost:8080).
VITE_API_URL=http://localhost:5000/api/v1

# Cloudinary Configuration
# 1. Sign up at https://cloudinary.com (free tier is sufficient)
# 2. Go to Settings > Upload > Add upload preset (set as "Unsigned")
# 3. Copy your Cloud Name from the Dashboard
# 4. Copy your Upload Preset name

VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
