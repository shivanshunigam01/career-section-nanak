# Local: copy to `.env.local` (loaded in all modes, gitignored).
# VITE_API_URL=http://localhost:5000/api/v1

# Production builds (`npm run build`) use `.env.production` in this repo:
#   VITE_API_URL=https://apivnfast.patliputragroup.com/api/v1
# (Must include `/api/v1` — the app appends paths like `/public/site-config`, `/leads`.)

# Optional: Nanak forms-only server port
# FORMS_API_PORT=5000

# API server behind nginx (on the server, not Vite)
# TRUST_PROXY=1
