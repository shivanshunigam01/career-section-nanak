# Patliputra live API (same value in `.env.development` + `.env.production` in this repo).
# Must include `/api/v1` — paths like `/public/site-config` and `/admin/...` are appended.
VITE_API_URL=https://apivnfast.patliputragroup.com/api/v1

# Local-only override (create this file; gitignored):
# VITE_API_URL=http://localhost:5000/api/v1

# Cloudinary — required for admin “Choose from computer” uploads (unsigned upload preset in Cloudinary console)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Nanak standalone forms server (optional)
# FORMS_API_PORT=5000
