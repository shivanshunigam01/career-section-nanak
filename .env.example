# Copy to `.env.local` (Vite loads it automatically).
# Then run the forms API: `npm run api` (or `npm run dev:with-api` for app + API together).

VITE_API_URL=http://localhost:5000/api/v1

# After deploy, open in a browser (replace with your API origin):
#   https://YOUR-API-HOST/           — HTML “Live” page
#   https://YOUR-API-HOST/api/v1/live — JSON (live, time, host)

# Optional: change forms API port (default 5000)
# FORMS_API_PORT=5000

# On the API server only (Node behind nginx / SSL): fixes correct https URL in /api/v1/live JSON
# TRUST_PROXY=1
